generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  fullName      String
  role          String
  passwordHash  String         @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  companyId     String?        @map("company_id")
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  projects      Project[]      @relation("ProjectCreatedBy")
  folders       Folder[]
  assets        Asset[]

  @@index([companyId])
}

model Company {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  users     User[]
  projects  Project[]

  @@map("companies")
}

model Project {
  id         String   @id @default(uuid())
  name       String
  status     String   @default("New")
  isFavorite Boolean  @default(false) @map("is_favorite")
  createdAt  DateTime @default(now()) @map("created_at")

  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdById String @map("created_by_id")
  createdBy   User   @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  folders Folder[]
  assets  Asset[]

  @@index([companyId])
  @@index([createdById])
  @@map("projects")
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentId String?  @map("parent_id")
  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderHierarchy")

  createdById String @map("created_by_id")
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  assets Asset[]

  @@index([projectId])
  @@index([parentId])
  @@index([createdById])
  @@map("folders")
}

model Asset {
  id                String   @id @default(uuid())
  name              String
  serialNumber      String?   @unique @map("serial_number")
  writtenDescription String? @db.Text @map("written_description")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  projectId         String   @map("project_id")
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  folderId          String?  @map("folder_id")
  folder            Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdById       String   @map("created_by_id")
  createdBy         User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  images            AssetImage[]
  voiceNotes        AssetVoiceNote[]

  @@index([projectId])
  @@index([folderId])
  @@index([createdById])
  @@index([name])
  @@map("assets")
}


model AssetImage {
  id         String   @id @default(uuid())
  url        String
  publicId   String?  @map("public_id")
  createdAt  DateTime @default(now()) @map("created_at")

  assetId    String   @map("asset_id")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_images")
}


model AssetVoiceNote {
  id         String   @id @default(uuid())
  url        String
  publicId   String?  @map("public_id")
  duration   Int?     // optional: store seconds later if needed
  createdAt  DateTime @default(now()) @map("created_at")

  assetId    String   @map("asset_id")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_voice_notes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
